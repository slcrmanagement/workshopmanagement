# GitHub Contents API — used in production to read/write source/*.json
# (Vercel's filesystem is read-only; local dev writes to source/ directly instead).
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Supabase — powers admin-only login for /administration.
# Get these from the Supabase dashboard: Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret — server-only, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
